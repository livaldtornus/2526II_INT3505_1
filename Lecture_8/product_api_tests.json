							"const jsonData = pm.response.json();",
							"pm.test(\"Check updated price\", function () {",
							"    pm.expect(jsonData.price).to.eql(250.00);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "PUT",
